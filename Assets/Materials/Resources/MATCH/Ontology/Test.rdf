        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#hasFirstName -->

    <owl:DatatypeProperty rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#hasFirstName"/>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#hasMaxValue -->

    <owl:DatatypeProperty rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#hasMaxValue">
        <rdfs:subPropertyOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#hasRangeValue"/>
    </owl:DatatypeProperty>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#hasMinValue -->

