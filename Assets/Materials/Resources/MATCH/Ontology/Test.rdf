<?xml version="1.0"?>
<rdf:RDF xmlns="https://ontology.staging.domus.usherbrooke.ca/MAO#"
     xml:base="https://ontology.staging.domus.usherbrooke.ca/MAO"
     xmlns:DUL="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#"
     xmlns:MAO="https://ontology.staging.domus.usherbrooke.ca/MAO#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:DUL1="http://www.loa-cnr.it/ontologies/DUL.owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO">
        <rdfs:comment>A simple family relationships ontology and associated instances. the description is of the family of Robert Stevens and the intention is to use the minimal of asserted relationships and the maximum of inference. To do this  I&apos;ve used role chains, nominals and properties hierarchies.</rdfs:comment>
    </owl:Ontology>
    


