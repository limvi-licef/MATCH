    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Appliances -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Appliances">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#EnvironmentElement"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#AppliancesStates -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#AppliancesStates">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#State"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Arch -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Arch">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Icons"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#hasFirstObject"/>
                <owl:allValuesFrom rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#EnvironmentElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#hasSecondObject"/>
                <owl:allValuesFrom rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#EnvironmentElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Armchair -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Armchair">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Assistance -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Assistance">
        <rdfs:comment>Contains all of the info about the assistances such as their content and their container</rdfs:comment>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#AssistanceActType -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#AssistanceActType">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Gradation"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#AssistanceLists -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#AssistanceLists">
        <rdfs:comment>Contains the list of all the assistances according to their linked scenario</rdfs:comment>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#AudioMessage -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#AudioMessage">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Container"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Bathroom -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Bathroom">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Rooms"/>
        <rdfs:label>Bathroom</rdfs:label>
        <hasLocation>dans la salle de bain</hasLocation>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Bed -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Bed">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#BedSideTable -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#BedSideTable">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Bedroom -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Bedroom">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Rooms"/>
        <rdfs:label>Bedroom</rdfs:label>
        <hasLocation>dans la chambre</hasLocation>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Bin -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Bin">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#BlockedState -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#BlockedState">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#StateOpenings"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Bookshelf -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Bookshelf">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Calendar -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Calendar">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Appliances"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Chair -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Chair">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#CleanTableState -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#CleanTableState">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#StateTable"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#ClosedState -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#ClosedState">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#StateOpenings"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Colors -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Colors">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Preference"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#CommunicationMode -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#CommunicationMode">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Preference"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#hasCommunicationMode"/>
                <owl:allValuesFrom rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Container"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Computer -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Computer">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Appliances"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#hasState"/>
                <owl:someValuesFrom rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#StateComputer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Container -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Container">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Assistance"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#isLinkedToAssistance"/>
                <owl:someValuesFrom rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Assistance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Content of the message being sent</rdfs:comment>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Cooker -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Cooker">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Appliances"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#hasState"/>
                <owl:someValuesFrom rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#StateCooker"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Corridor -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Corridor">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Rooms"/>
        <rdfs:label>Corridor</rdfs:label>
        <hasLocation>dans le couloir</hasLocation>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Couch -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Couch">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
        <rdfs:comment>The terms “sofa” and “couch” have two very different origins. The first one comes from the Arabic term “suffah” which describes a bench covered with blankets and cushions.The second one comes from the French “couche” and it’s a piece of furniture that was popularly used in the Victorian era.

As for their structure and shape, sofas usually feature two armrests and a uniform back while couches generally feature one armrest or none at all and a tapered back.</rdfs:comment>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Cupboards -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Cupboards">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#Desk -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#Desk">
        <rdfs:subClassOf rdf:resource="https://ontology.staging.domus.usherbrooke.ca/MAO#Furniture"/>
    </owl:Class>
    


    <!-- https://ontology.staging.domus.usherbrooke.ca/MAO#DiningRoom -->

    <owl:Class rdf:about="https://ontology.staging.domus.usherbrooke.ca/MAO#DiningRoom">
